<p style="margin: 0 0 16px; font-size: 16px; color: #1c1917; font-weight: 600;">
  <%= t("devise.mailer.reset_password_instructions.greeting", name: @resource.name) %>
</p>

<p style="margin: 0 0 24px; font-size: 14px; color: #44403c; line-height: 1.6;">
  <%= t("devise.mailer.reset_password_instructions.body") %>
</p>

<% reset_url = "#{root_url}reset-password?token=#{@token}" %>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin: 0 0 24px;">
  <tr>
    <td align="center">
      <a href="<%= reset_url %>"
         style="display: inline-block; padding: 12px 32px; background-color: #0f766e; color: #ffffff; text-decoration: none; border-radius: 8px; font-size: 14px; font-weight: 600;">
        <%= t("devise.mailer.reset_password_instructions.action") %>
      </a>
    </td>
  </tr>
</table>

<p style="margin: 0 0 8px; font-size: 12px; color: #a8a29e;">
  <%= t("devise.mailer.reset_password_instructions.fallback", default: t("devise.mailer.confirmation_instructions.fallback")) %>
</p>
<p style="margin: 0 0 16px; font-size: 12px; color: #a8a29e; word-break: break-all;">
  <%= reset_url %>
</p>

<p style="margin: 0 0 8px; font-size: 13px; color: #78716c; line-height: 1.5;">
  <%= t("devise.mailer.reset_password_instructions.ignore") %>
</p>

<p style="margin: 0; font-size: 12px; color: #a8a29e;">
  <%= t("devise.mailer.reset_password_instructions.expiry", hours: 6) %>
</p>
