{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["app/javascript/*"],
      "@components/*": ["app/javascript/components/*"],
      "@composables/*": ["app/javascript/composables/*"],
      "@layouts/*": ["app/javascript/layouts/*"],
      "@lib/*": ["app/javascript/lib/*"],
      "@locales": ["app/javascript/locales/index.ts"],
      "@plugins/*": ["app/javascript/plugins/*"],
      "@router": ["app/javascript/router/index.ts"],
      "@services/*": ["app/javascript/services/*"],
      "@stores/*": ["app/javascript/stores/*"],
      "@views/*": ["app/javascript/views/*"]
    }
  },
  "include": [
    "app/javascript/**/*.ts",
    "app/javascript/**/*.d.ts",
    "app/javascript/**/*.vue"
  ]
}
